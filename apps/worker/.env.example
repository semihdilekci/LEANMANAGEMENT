NODE_ENV=development
WORKER_HTTP_PORT=3002
DATABASE_URL=postgresql://postgres:160219@localhost:5432/leanmgmt_dev?schema=public
REDIS_URL=redis://127.0.0.1:6379
# API ile aynı 64 hex — e-posta alıcısı decrypt (user:email:v1)
APP_PII_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# SLA taraması (5 dk) — `sla-overdue.worker.ts` + `sla-overdue.ts`
# SLA_OVERDUE_QUEUE_NAME=sla-overdue

# Faz 7 — bildirim e-postası (BullMQ consumer + digest/cleanup)
# NOTIFICATION_EMAIL_QUEUE_NAME=notification-email-outbound
# EMAIL_SENDING_MODE=noop
# SES sandbox / prod: ses + doğrulanmış gönderici
# EMAIL_SENDING_MODE=ses
# SES_FROM_ADDRESS=noreply@verified-domain.example
# AWS_REGION=eu-central-1
# WEB_APP_BASE_URL=http://localhost:3000
# Günlük digest + 90 gün in-app silme aralığı (ms), varsayılan 86400000
# NOTIFICATION_CRON_INTERVAL_MS=86400000
