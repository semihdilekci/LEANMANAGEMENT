{
  "name": "@leanmgmt/worker",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "generate:prisma": "pnpm --dir ../api exec prisma generate",
    "prebuild": "pnpm --filter @leanmgmt/shared-utils build && pnpm run generate:prisma",
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1036.0",
    "@aws-sdk/client-sesv2": "^3.1036.0",
    "@leanmgmt/shared-schemas": "workspace:*",
    "@leanmgmt/shared-types": "workspace:*",
    "@leanmgmt/shared-utils": "workspace:*",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-fastify": "^10.4.15",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "bullmq": "^5.76.1",
    "fastify": "^4.28.1",
    "handlebars": "4.7.8",
    "ioredis": "^5.4.2",
    "pg": "8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@leanmgmt/config": "workspace:*",
    "@nestjs/cli": "^10.4.9",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "prisma": "^7.8.0",
    "testcontainers": "^11.14.0",
    "tsx": "^4.19.2",
    "typescript": "catalog:",
    "typescript-eslint": "^8.21.0",
    "vitest": "catalog:"
  }
}
