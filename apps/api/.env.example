API_PORT=3001
DATABASE_URL=postgresql://postgres:160219@localhost:5432/leanmgmt_dev?schema=public
# Yerel: `pnpm services:redis` (repo kökü) veya `docker compose up -d redis`
REDIS_URL=redis://127.0.0.1:6379
# openssl rand -hex 32 (x2)
APP_PII_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
APP_PII_PEPPER=fedcba9876543210fedcba9876543210fedcba9876543210fedcba9876543210
JWT_ACCESS_SECRET_CURRENT=15b118a09bbab877cba453483f275966
# Yalnızca test: true iken password-reset yanıtında token döner (üretimde kullanma)
# AUTH_EXPOSE_RESET_TOKEN=false

# İzleme (opsiyonel)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Doküman yükleme (S3 + tarama kuyruğu) — yerel: noop + placeholder; prod: s3 + gerçek bucket
# DOCUMENTS_STORAGE_DRIVER=noop
# S3_DOCUMENTS_BUCKET=leanmgmt-dev-documents
# AWS_REGION=eu-central-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_ENDPOINT_URL=
# DOCUMENT_SCAN_QUEUE_NAME=document-virus-scan

# Faz 7 — transactional bildirim e-postası (BullMQ; worker tüketir)
# NOTIFICATION_EMAIL_QUEUE_NAME=notification-email-outbound

# prisma/seed.ts (opsiyonel)
# SUPERADMIN_EMAIL=superadmin@leanmgmt.local
# SUPERADMIN_PASSWORD=AdminPass123!@#
# SUPERADMIN_SICIL=00000001
# SEED_CONSENT_PENDING_EMAIL=consentpending@leanmgmt.local
# SEED_CONSENT_PENDING_PASSWORD=PendingPass123!@#

# --- Faz 2.1 OIDC (Google dev / Keycloak prod) — docs/03_API_CONTRACTS.md §6, ADR 0008 ---
# OIDC_ENABLED=false iken aşağıdakiler yok sayılır (CI / yerel varsayılan).
# OIDC_ENABLED=true iken: OIDC_ISSUER, OIDC_CLIENT_ID, OIDC_REDIRECT_URI zorunlu.
# OIDC_REDIRECT_URI pathname tam olarak: /api/v1/auth/oauth/google/callback
# Google issuer (https://accounts.google.com) + production dışı: OIDC_CLIENT_SECRET zorunlu.
# Google + production: client secret zorunlu değildir (canlıda Keycloak hedeflenir).
# | Değişken             | Örnek / not |
# | OIDC_ENABLED         | false |
# | OIDC_ISSUER          | https://accounts.google.com — veya Keycloak realm issuer URL |
# | OIDC_CLIENT_ID       | Google Cloud OAuth Web client ID |
# | OIDC_CLIENT_SECRET   | Google web client secret (dev/staging/test); Keycloak’ta opsiyonel |
# | OIDC_REDIRECT_URI    | http://127.0.0.1:3001/api/v1/auth/oauth/google/callback |
# | OIDC_SCOPES          | (opsiyonel) varsayılan: openid email profile |
# | WEB_PUBLIC_ORIGIN    | (opsiyonel) Next kökü — dolu iken OIDC callback sonrası /login?oidc=… 302 (JSON sayfası yok). OIDC_ENABLED=true iken OIDC_REDIRECT_URI ile aynı origin olmalı (localhost vs 127.0.0.1 karıştırma). |
# OIDC_ENABLED=false
# OIDC_ISSUER=https://accounts.google.com
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=http://127.0.0.1:3001/api/v1/auth/oauth/google/callback
# OIDC_SCOPES=openid email profile
# WEB_PUBLIC_ORIGIN=http://localhost:3000
