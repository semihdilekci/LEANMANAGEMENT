# Next.js /api → Nest arka uç (yerel geliştirme)
# API_UPSTREAM_URL=http://127.0.0.1:3001

# Faz 2.1 İter 3 — OIDC giriş butonu: true iken /login’de "Kurumsal hesap ile giriş" (aynı origin /api/v1/auth/oauth/google).
# NEXT_PUBLIC_OIDC_LOGIN_BUTTON=false

# Email+şifre formu: false iken yalnız OIDC (bootstrap/E2E dışı ortamlar).
# NEXT_PUBLIC_PASSWORD_LOGIN_ENABLED=true

# API’de WEB_PUBLIC_ORIGIN ile eşleşen kök (cookie’ler için localhost vs 127.0.0.1 karıştırma).

# İzleme (opsiyonel, yalnızca istemci)
# NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
