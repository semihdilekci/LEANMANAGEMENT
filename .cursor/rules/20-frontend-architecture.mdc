## Middleware — Auth Redirect

```typescript
// app/middleware.ts
import { NextResponse } from 'next/server';

export function middleware(request) {
  const isAuthenticated = request.cookies.has('refresh_token');
  const { pathname } = request.nextUrl;

  // Auth routes — authenticated user → redirect dashboard
  if (isAuthenticated && (pathname === '/login' || pathname === '/reset-password')) {
    return NextResponse.redirect(new URL('/dashboard', request.url));
  }

  // App routes — unauthenticated → redirect login
  const isPublic = ['/login', '/reset-password', '/forgot-password'].includes(pathname);
  if (!isAuthenticated && !isPublic && !pathname.startsWith('/api')) {
    return NextResponse.redirect(new URL('/login', request.url));
  }

  return NextResponse.next();
}

export const config = {
  matcher: ['/((?!_next/static|_next/image|favicon.ico).*)'],
};
```

Middleware hızlı — sadece cookie varlığı kontrol. Full auth validation `useAuthStore` / `GET /auth/me` ile client-side.

## API Client — Axios Singleton

```typescript
// lib/api-client.ts
import axios from 'axios';
import { useAuthStore } from '@/stores/auth-store';

export const apiClient = axios.create({
  baseURL: process.env.NEXT_PUBLIC_API_URL,
  withCredentials: true,  // send cookies
});

apiClient.interceptors.request.use((config) => {
  const { accessToken, csrfToken } = useAuthStore.getState();
  if (accessToken) {
    config.headers.Authorization = `Bearer ${accessToken}`;
  }
  if (csrfToken && ['post', 'put', 'patch', 'delete'].includes(config.method ?? '')) {
    config.headers['X-CSRF-Token'] = csrfToken;
  }
  return config;
});

// 401 → refresh + retry
apiClient.interceptors.response.use(
  (r) => r,
  async (err) => {
    if (err.response?.status === 401 && err.response?.data?.error?.code === 'AUTH_TOKEN_EXPIRED') {
      await refreshAccessToken();
      return apiClient(err.config);
    }
    throw err;
  },
);
```

## File Naming

- Components: PascalCase `.tsx` — `UserForm.tsx`, `ProcessDetailCard.tsx`
- Hooks: camelCase with `use` prefix — `useAuthStore.ts`, `useUnsavedChangesWarning.ts`
- Pages: `page.tsx` (App Router conv.)
- Layouts: `layout.tsx`
- Queries/mutations: camelCase — `users.ts`, `processes.ts`
- Stores: `<name>-store.ts` — `auth-store.ts`, `ui-preferences-store.ts`

## Providers Setup

Root layout'ta `<Providers>`:

```typescript
// app/layout.tsx
import { Providers } from '@/components/Providers';

export default function RootLayout({ children }) {
  return (
    <html lang="tr">
      <body>
        <Providers>{children}</Providers>
      </body>
    </html>
  );
}

// components/Providers.tsx
'use client';
export function Providers({ children }) {
  const [queryClient] = useState(() => new QueryClient({
    defaultOptions: { queries: { staleTime: 30_000, refetchOnWindowFocus: false } },
  }));
  return (
    <QueryClientProvider client={queryClient}>
      {children}
      <Toaster />
    </QueryClientProvider>
  );
}
```

## Banned Patterns

- `'use client'` herhangi bir dosyada default (gereksiz client overhead)
- localStorage/sessionStorage access (XSS + tokens risk)
- Server state Zustand'a koyma (TanStack Query kullan)
- Page component içinde business logic (feature component'e çıkar)
- Manuel fetch/XHR (apiClient axios singleton)
- `useEffect` for data fetching (TanStack Query kullan)
- Global CSS eklemek (Tailwind + component-scoped)
- Full-page re-render (route-level `revalidate` yeter)

