```

## SlaBadge

Task SLA durumu için:

```typescript
// components/shared/SlaBadge.tsx
type SlaStatus = 'not-due' | 'approaching' | 'overdue';

function getSlaStatus(dueAt: Date): SlaStatus {
  const now = new Date();
  const hoursUntil = (dueAt.getTime() - now.getTime()) / (60 * 60 * 1000);
  if (hoursUntil < 0) return 'overdue';
  if (hoursUntil < 24) return 'approaching';
  return 'not-due';
}

export function SlaBadge({ dueAt }: { dueAt: Date }) {
  const status = getSlaStatus(dueAt);
  const colors = {
    'not-due': 'bg-gray-100 text-gray-700',
    'approaching': 'bg-yellow-100 text-yellow-800',
    'overdue': 'bg-red-100 text-red-800',
  };
  return (
    <span className={`inline-flex px-2 py-1 text-xs font-medium rounded-full ${colors[status]}`}>
      {formatRelative(dueAt)}
    </span>
  );
}
```

