### Integration test — endpoint guard

```typescript
describe('POST /users/:id/sessions/:sessionId/revoke', () => {
  it('USER_SESSION_REVOKE permission olmadan 403 döner', async () => {
    const regular = await authHelper.loginAs('regular@test.com');
    
    const res = await request(app.getHttpServer())
      .post(`/api/v1/users/${someUserId}/sessions/${sessionId}/revoke`)
      .set('Authorization', `Bearer ${regular.accessToken}`);

    expect(res.status).toBe(403);
    expect(res.body.error.code).toBe('PERMISSION_DENIED');
  });

  it('USER_SESSION_REVOKE olan kullanıcı session sonlandırabilir', async () => {
    const admin = await authHelper.loginAs('admin@test.com');
    
    const res = await request(app.getHttpServer())
      .post(`/api/v1/users/${someUserId}/sessions/${sessionId}/revoke`)
      .set('Authorization', `Bearer ${admin.accessToken}`);

    expect(res.status).toBe(200);
    
    // Audit verify
    const audit = await prisma.audit_logs.findFirst({
      where: { action: 'USER_SESSION_REVOKED', entity_id: sessionId },
    });
    expect(audit).toBeDefined();
  });
});
```

### Cache invalidation test

```typescript
it('role permission değişiminde etkilenen user cache invalidate olur', async () => {
  const user = await createTestUserWithRole(adminRoleId);
  await permissionResolver.getUserPermissions(user.id);  // cache warm
  
  const cachedBefore = await redis.get(`user_permissions:${user.id}`);
  expect(cachedBefore).toBeDefined();

  await rolesService.updateRolePermissions(adminRoleId, [/* new perms */], actor);

  const cachedAfter = await redis.get(`user_permissions:${user.id}`);
  expect(cachedAfter).toBeNull();  // invalidated
});
```

