## Step 6: Cache Invalidation Tetikle

Yeni permission'ı role'e atayan endpoint otomatik cache invalidate etmeli:

```typescript
// apps/api/src/roles/roles.service.ts
@Audit('ROLE_PERMISSION_UPDATED', 'ROLE')
async updateRolePermissions(
  roleId: string,
  permissionKeys: Permission[],
  actor: AuthenticatedUser,
) {
  await this.prisma.$transaction(async (tx) => {
    // Mevcut permission'ları sil, yenileri ekle
    await tx.role_permissions.deleteMany({ where: { role_id: roleId } });
    await tx.role_permissions.createMany({
      data: permissionKeys.map((key) => ({ role_id: roleId, permission_key: key })),
    });
  });

  // CRITICAL: Bu role'e sahip tüm user'ların cache'ini invalidate et
  this.eventEmitter.emit('role.permissions.changed', { roleId });
}
```

```typescript
// apps/api/src/roles/role-cache-invalidation.listener.ts
@Injectable()
export class RoleCacheInvalidationListener {
  constructor(private permissionResolver: PermissionResolverService) {}

  @OnEvent('role.permissions.changed')
  async handlePermissionsChanged({ roleId }: { roleId: string }) {
    await this.permissionResolver.invalidateRole(roleId);
  }
}
```

Permission resolver rule (`12-backend-permissions.mdc`) detay.

