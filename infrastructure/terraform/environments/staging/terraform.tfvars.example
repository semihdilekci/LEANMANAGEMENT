# Copy to terraform.tfvars (gitignored).

aws_region = "eu-central-1"

acm_certificate_arn = "arn:aws:acm:eu-central-1:ACCOUNT_ID:certificate/UUID"
github_repository   = "your-org/LeanManagement"

terraform_remote_state_bucket_arn     = "arn:aws:s3:::leanmgmt-terraform-state-staging"
terraform_remote_state_lock_table_arn = "arn:aws:dynamodb:eu-central-1:ACCOUNT_ID:table/leanmgmt-terraform-locks-staging"

# Zorunlu: Next.js / web uygulamasının tam origin’i (sonda / yok). CORS olmadan tarayıcı S3 PUT "failed to fetch" verir.
# documents_upload_cors_allowed_origins = ["https://staging-app.example.com"]
