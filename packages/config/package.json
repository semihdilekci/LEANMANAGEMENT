{
  "name": "@leanmgmt/config",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "files": [
    "eslint",
    "tsconfig",
    "vitest",
    "prettier.json"
  ],
  "exports": {
    "./eslint": "./eslint/base.mjs",
    "./tsconfig/base": "./tsconfig/base.json",
    "./tsconfig/nextjs": "./tsconfig/nextjs.json",
    "./vitest/base": "./vitest/base.config.ts"
  },
  "scripts": {
    "build": "node --input-type=module -e \"import fs from 'node:fs'; fs.mkdirSync('dist',{recursive:true}); fs.writeFileSync('dist/.gitkeep','');\"",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "echo 'no tests in config'"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "catalog:",
    "eslint-config-prettier": "^10.0.1",
    "typescript": "catalog:",
    "typescript-eslint": "^8.21.0",
    "vitest": "catalog:"
  }
}
